{
  "name": "nlpc",
  "version": "1.0.0",
  "description": "natural-language programming language compiler - english in, runnable c++ out",
  "type": "module",
  "bin": {
    "nlpc": "bin/nlpc.mjs"
  },
  "main": "lib/runner.mjs",
  "scripts": {
    "test": "node --test --test-reporter=spec tests/unit tests/integration tests/negative tests/security",
    "test:e2e": "node --test --test-reporter=spec tests/e2e",
    "test:perf": "node tests/performance/bench.mjs",
    "smoke": "node tests/smoke.mjs",
    "build:binary": "node scripts/build.mjs",
    "postinstall": "node -e \"console.log('nlpc installed. run \\\\\\\"nlpc doctor\\\\\\\" to check your toolchain, or \\\\\\\"nlpc setup\\\\\\\" to install missing tools. update: npm i -g crazystuffxyz/nlpc')\""
  },
  "files": [
    "bin",
    "lib",
    "scripts",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "nlp",
    "compiler",
    "ollama",
    "cpp",
    "vcpkg",
    "natural-language",
    "code-generation"
  ],
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "ollama": "^0.6.3",
    "ora": "^8.2.0",
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "pkg": "^5.8.1"
  }
}
